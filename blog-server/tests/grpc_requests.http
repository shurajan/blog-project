### 24. DeletePost — happy path (expect empty response)
GRPC {{host}}/blog.v1.PostEditorService/DeletePost
Authorization: Bearer {{auth_token}}

{
  "id": {{post_id}}
}

> {%
    client.test("Response OK (empty body)", () => {
        // google.protobuf.Empty — тело пустое, статус 0
        client.assert(response.status === 0 || response.body !== undefined, "Unexpected error");
    });
%}


