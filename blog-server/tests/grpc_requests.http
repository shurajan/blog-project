### POSTS — защищённые endpoints (PostEditorService)
### =====================================================================

### 11. CreatePost — без токена (expect UNAUTHENTICATED)
GRPC {{host}}/blog.v1.PostEditorService/CreatePost

{
  "title": "Anonymous attempt",
  "content": "Should fail"
}

> {%
    client.test("Status is UNAUTHENTICATED (16)", () => {
        client.assert(response.status === 16, "Expected UNAUTHENTICATED(16), got " + response.status);
    });
%}


### 12. CreatePost — с мусорным токеном (expect UNAUTHENTICATED)
GRPC {{host}}/blog.v1.PostEditorService/CreatePost
Authorization: Bearer not.a.real.jwt.token

{
  "title": "Invalid token attempt",
  "content": "Should fail"
}

> {%
    client.test("Status is UNAUTHENTICATED (16)", () => {
        client.assert(response.status === 16, "Expected UNAUTHENTICATED(16), got " + response.status);
    });
%}


### 13. CreatePost — happy path
GRPC {{host}}/blog.v1.PostEditorService/CreatePost
Authorization: Bearer {{auth_token}}

{
  "title": "First post",
  "content": "Hello, world!"
}

> {%
    client.test("Response received", () => {
        client.assert(response.body, "Empty response");
    });
    client.test("Post has id, title, content, author_id", () => {
        client.assert(response.body.id, "No id");
        client.assert(response.body.title === "First post", "Wrong title: " + response.body.title);
        client.assert(response.body.content === "Hello, world!", "Wrong content");
        client.assert(response.body.authorId, "No author_id");
    });
    client.global.set("post_id", response.body.id);
%}


### 14. CreatePost — пустой title (expect INVALID_ARGUMENT)
GRPC {{host}}/blog.v1.PostEditorService/CreatePost
Authorization: Bearer {{auth_token}}

{
  "title": "   ",
  "content": "some content"
}

> {%
    client.test("Status is INVALID_ARGUMENT (3)", () => {
        client.assert(response.status === 3, "Expected INVALID_ARGUMENT(3), got " + response.status);
    });
%}


### 15. CreatePost — пустой content (expect INVALID_ARGUMENT)
GRPC {{host}}/blog.v1.PostEditorService/CreatePost
Authorization: Bearer {{auth_token}}

{
  "title": "Title only",
  "content": "   "
}

> {%
    client.test("Status is INVALID_ARGUMENT (3)", () => {
        client.assert(response.status === 3, "Expected INVALID_ARGUMENT(3), got " + response.status);
    });
%}


### 16. GetPost — только что созданный пост (expect OK)
GRPC {{host}}/blog.v1.PostService/GetPost

{
  "id": {{post_id}}
}

> {%
    client.test("Response received", () => {
        client.assert(response.body, "Empty response");
    });
    client.test("Returned correct post", () => {
        client.assert(
            String(response.body.id) === String(client.global.get("post_id")),
            "Post id mismatch"
        );
    });
%}


### 17. UpdatePost — happy path
GRPC {{host}}/blog.v1.PostEditorService/UpdatePost
Authorization: Bearer {{auth_token}}

{
  "id": {{post_id}},
  "title": "First post (updated)"
}

> {%
    client.test("Response received", () => {
        client.assert(response.body, "Empty response");
    });
    client.test("Title updated", () => {
        client.assert(
            response.body.title === "First post (updated)",
            "Title not updated: " + response.body.title
        );
    });
    client.test("Content preserved", () => {
        client.assert(
            response.body.content === "Hello, world!",
            "Content was overwritten: " + response.body.content
        );
    });
%}


