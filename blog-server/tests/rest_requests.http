### =====================================================================
### Blog Server — Auth + Posts API Integration tests
### (RustRover / IntelliJ HTTP Client) ONLY
### RUN ON CLEAN DATABASE
### =====================================================================

@host = http://127.0.0.1:8080
@username = alice
@email = alice@example.com
@password = Secret123

@other_username = mallory
@other_email = mallory@example.com
@other_password = Hacker123


### =====================================================================
### AUTH
### =====================================================================

### 1. Register alice — happy path (expect 201)
POST {{host}}/api/auth/register
Content-Type: application/json

{
  "username": "{{username}}",
  "email": "{{email}}",
  "password": "{{password}}"
}

> {%
    client.test("Status is 201", () => {
        client.assert(response.status === 201, "Expected 201, got " + response.status);
    });
    client.test("Token returned", () => {
        client.assert(response.body.token, "No token in response");
    });
    client.test("User returned", () => {
        client.assert(response.body.user && response.body.user.id, "No user.id in response");
    });
    client.global.set("auth_token", response.body.token);
    client.global.set("user_id", response.body.user.id);
%}


### 2. Register — duplicate (expect 409)
POST {{host}}/api/auth/register
Content-Type: application/json

{
  "username": "{{username}}",
  "email": "{{email}}",
  "password": "{{password}}"
}

> {%
    client.test("Status is 409", () => {
        client.assert(response.status === 409, "Expected 409, got " + response.status);
    });
%}


### 3. Login alice — happy path (expect 200)
POST {{host}}/api/auth/login
Content-Type: application/json

{
  "username": "{{username}}",
  "password": "{{password}}"
}

> {%
    client.test("Status is 200", () => {
        client.assert(response.status === 200, "Expected 200, got " + response.status);
    });
    client.test("Token returned", () => {
        client.assert(response.body.token, "No token in response");
    });
    client.global.set("auth_token", response.body.token);
%}


### 4. Login — wrong password (expect 401)
POST {{host}}/api/auth/login
Content-Type: application/json

{
  "username": "{{username}}",
  "password": "totally_wrong"
}

> {%
    client.test("Status is 401", () => {
        client.assert(response.status === 401, "Expected 401, got " + response.status);
    });
%}


### 5. Login — unknown user (expect 401, NOT 404)
POST {{host}}/api/auth/login
Content-Type: application/json

{
  "username": "ghost_user_does_not_exist",
  "password": "whatever"
}

> {%
    client.test("Status is 401 (not 404 — user enumeration check)", () => {
        client.assert(response.status === 401, "Expected 401, got " + response.status);
    });
%}


### 6. Register — missing field (expect 400)
POST {{host}}/api/auth/register
Content-Type: application/json

{
  "username": "bob",
  "email": "bob@example.com"
}

> {%
    client.test("Status is 400", () => {
        client.assert(response.status === 400, "Expected 400, got " + response.status);
    });
%}


### 7. Register — malformed JSON (expect 400)
POST {{host}}/api/auth/register
Content-Type: application/json

{"username": "bob"}

> {%
    client.test("Status is 400", () => {
        client.assert(response.status === 400, "Expected 400, got " + response.status);
    });
%}


### 8. Register mallory (second user, for forbidden tests)
POST {{host}}/api/auth/register
Content-Type: application/json

{
  "username": "{{other_username}}",
  "email": "{{other_email}}",
  "password": "{{other_password}}"
}

> {%
    // 201 if fresh db, 409 if already exists — both are fine, we just need a token
    client.test("Status is 201 or 409", () => {
        client.assert(
            response.status === 201 || response.status === 409,
            "Expected 201 or 409, got " + response.status
        );
    });
    if (response.status === 201) {
        client.global.set("other_token", response.body.token);
    }
%}


### 9. Login mallory — гарантированно получаем токен второго юзера
POST {{host}}/api/auth/login
Content-Type: application/json

{
  "username": "{{other_username}}",
  "password": "{{other_password}}"
}

> {%
    client.test("Status is 200", () => {
        client.assert(response.status === 200, "Expected 200, got " + response.status);
    });
    client.global.set("other_token", response.body.token);
%}


### =====================================================================
### POSTS — публичные endpoints
### =====================================================================

### 10. List posts — пустой список или уже что-то есть (expect 200)
GET {{host}}/api/posts

> {%
    client.test("Status is 200", () => {
        client.assert(response.status === 200, "Expected 200, got " + response.status);
    });
    client.test("Response has pagination shape", () => {
        client.assert(Array.isArray(response.body.posts), "posts is not an array");
        client.assert(typeof response.body.total === "number", "total missing");
        client.assert(typeof response.body.limit === "number", "limit missing");
        client.assert(typeof response.body.offset === "number", "offset missing");
    });
%}


### 11. List posts — с пагинацией
GET {{host}}/api/posts?limit=5&offset=0

> {%
    client.test("Status is 200", () => {
        client.assert(response.status === 200, "Expected 200, got " + response.status);
    });
    client.test("limit respected", () => {
        client.assert(response.body.limit === 5, "Expected limit=5, got " + response.body.limit);
        client.assert(response.body.posts.length <= 5, "Too many posts");
    });
%}


### 12. Get post by non-existent id (expect 404)
GET {{host}}/api/posts/999999

> {%
    client.test("Status is 404", () => {
        client.assert(response.status === 404, "Expected 404, got " + response.status);
    });
%}


