### 18. Get the created post (expect 200)
GET {{host}}/api/posts/{{post_id}}

> {%
    client.test("Status is 200", () => {
        client.assert(response.status === 200, "Expected 200, got " + response.status);
    });
    client.test("Returned correct post", () => {
        client.assert(response.body.id === parseInt(client.global.get("post_id")),
            "Post id mismatch");
    });
%}


### 19. Update post — happy path (expect 200)
PUT {{host}}/api/posts/{{post_id}}
Authorization: Bearer {{auth_token}}
Content-Type: application/json

{
  "title": "First post (updated)"
}

> {%
    client.test("Status is 200", () => {
        client.assert(response.status === 200, "Expected 200, got " + response.status);
    });
    client.test("Title updated", () => {
        client.assert(response.body.title === "First post (updated)",
            "Title not updated: " + response.body.title);
    });
    client.test("Content preserved", () => {
        client.assert(response.body.content === "Hello, world!",
            "Content was overwritten: " + response.body.content);
    });
%}


