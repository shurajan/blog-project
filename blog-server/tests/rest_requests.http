### 15. Create post — happy path (expect 201)
POST {{host}}/api/posts
Authorization: Bearer {{auth_token}}
Content-Type: application/json

{
  "title": "First post",
  "content": "Hello, world!"
}

> {%
    client.test("Status is 201", () => {
        client.assert(response.status === 201, "Expected 201, got " + response.status);
    });
    client.test("Post has id, title, content, author_id", () => {
        client.assert(response.body.id, "No id");
        client.assert(response.body.title === "First post", "Wrong title");
        client.assert(response.body.content === "Hello, world!", "Wrong content");
        client.assert(response.body.author_id, "No author_id");
    });
    client.global.set("post_id", response.body.id);
%}


### 16. Create post — empty title (expect 400)
POST {{host}}/api/posts
Authorization: Bearer {{auth_token}}
Content-Type: application/json

{
  "title": "   ",
  "content": "content"
}

> {%
